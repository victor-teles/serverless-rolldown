    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "validate:example": "bun ./scripts/validate-example.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@biomejs/biome": "2.4.8"
  },
  "peerDependencies": {
    "serverless": "^4",
    "typescript": "^5",
    "rolldown": "^1.0.0-rc.10"
  }
}
