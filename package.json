{
  "name": "serverless-rolldown",
  "version": "0.0.3",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "format": "biome check --javascript-linter-enabled=false --write",
