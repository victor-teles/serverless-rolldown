    "dev": "serverless offline"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "rolldown": "^1.0.0-rc.10",
    "serverless": "^4.33.0",
    "serverless-offline": "14.5.0",
    "typescript": "^5.0.0",
    "@aws-sdk/client-s3": "^3.868.0",
    "@aws-sdk/client-sqs": "^3.868.0"
  }
}
